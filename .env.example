ANTHROPIC_API_KEY=your_anthropic_key_here
GOOGLE_API_KEY=your_google_api_key_here

# Optional: path where ChromaDB persists its vector store (default: ./data/chroma_db)
CHROMA_PATH=./data/chroma_db

# Whisper model size: tiny, base, small, medium, large-v3
# larger = more accurate, slower. "base" is good for prototyping.
WHISPER_MODEL=base

# Sentence-transformers embedding model
EMBEDDING_MODEL=all-MiniLM-L6-v2

# Set to "true" to use Gemini 1.5 Pro for native video/audio understanding (sees visuals,
# whiteboards, slides — not just audio). Set to "false" to use local faster-whisper instead.
USE_GEMINI_VISION=true
